:root{
  --bg:#f4f7fb;--card:#fff;--text:#162033;--muted:#6f7a8f;--line:#dfe7f1;
  --primary:#8fa8e8;--primary-dark:#5a78d6;--primary-soft:#eaf0ff;
  --success:#4caf50;--success-soft:#ecf8ec;--warning:#d99112;--warning-soft:#fbf2da;
  --danger:#df544d;--danger-soft:#fdecec;--violet:#8b5cf6;--violet-soft:#efe8ff;
  --shadow:0 14px 30px rgba(31,52,91,.08);--radius:24px;
}
*{box-sizing:border-box} body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif;background:var(--bg);color:var(--text)}
a{text-decoration:none;color:inherit}
.app{display:grid;grid-template-columns:88px 1fr;min-height:100vh}
.sidebar{background:#fff;border-right:1px solid var(--line);padding:18px 14px;display:flex;flex-direction:column;gap:14px;align-items:center}
.logo{width:56px;height:56px;border-radius:18px;background:linear-gradient(135deg,var(--primary-dark),var(--primary));color:#fff;font-size:22px;font-weight:800;display:grid;place-items:center;box-shadow:var(--shadow);margin-bottom:6px}
.side-icon{width:46px;height:46px;border-radius:15px;border:1px solid var(--line);background:#fff;color:var(--muted);display:grid;place-items:center;font-size:18px}
.main{padding:28px}
.topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:18px}
h1,h2,h3,h4,p{margin:0}
.title-wrap h1{font-size:34px;margin-bottom:8px;line-height:1.08}
.title-wrap p{color:var(--muted);font-size:14px;max-width:850px}
.top-actions,.header-inline,.tabs{display:flex;gap:12px;flex-wrap:wrap;align-items:center}
.btn{border:0;border-radius:16px;padding:13px 20px;font-weight:700;cursor:pointer;display:inline-block}
.btn-primary{background:var(--primary);color:#fff;box-shadow:var(--shadow)}
.btn-secondary{background:#fff;border:1px solid var(--line);color:var(--text)}
.tabs{margin-bottom:18px}
.tab{background:#fff;border:1px solid var(--line);color:var(--muted);padding:12px 18px;border-radius:16px;font-weight:700}
.tab.active{background:var(--primary-soft);color:var(--primary-dark);border-color:#cfdcff}
.card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden}
.card + .card{margin-top:18px}
.card-header{padding:20px 24px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap}
.card-header p,.small,.muted{color:var(--muted);font-size:13px}
.card-body{padding:22px 24px 24px}
.grid-2{display:grid;grid-template-columns:1.3fr .9fr;gap:18px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.stat{border:1px solid var(--line);border-radius:18px;padding:16px;background:#fff}
.label{font-size:13px;color:var(--muted);margin-bottom:8px}.value{font-size:30px;font-weight:800;line-height:1;margin-bottom:8px}
.progress{width:100%;height:10px;background:#edf2f8;border-radius:999px;overflow:hidden;margin-top:8px}
.progress>span{display:block;height:100%;background:linear-gradient(90deg,var(--primary),var(--primary-dark));border-radius:inherit}
.progress.success>span{background:linear-gradient(90deg,#73c878,#4caf50)}
.progress.warning>span{background:linear-gradient(90deg,#f0c055,#d99112)}
.progress.danger>span{background:linear-gradient(90deg,#f08e8e,#df544d)}
.badge{display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;font-size:12px;font-weight:700;white-space:nowrap}
.badge.success{color:#328a36;background:var(--success-soft)} .badge.warning{color:#a16a04;background:var(--warning-soft)}
.badge.danger{color:#b63c35;background:var(--danger-soft)} .badge.info{color:var(--primary-dark);background:var(--primary-soft)}
.badge.violet{color:#7342e8;background:var(--violet-soft)} .badge.gray{color:#5d697d;background:#eff3f8}
table{width:100%;border-collapse:collapse} th,td{padding:14px 12px;border-bottom:1px solid var(--line);font-size:14px;vertical-align:top;text-align:left}
th{color:var(--muted);font-size:12px;text-transform:uppercase;letter-spacing:.04em;font-weight:800}
.input{width:100%;background:#fff;border:1px solid #ccd8e6;border-radius:16px;min-height:58px;padding:16px 18px;color:var(--text);font-size:16px}
.form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px 24px}.form-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.field label{display:block;font-weight:800;font-size:15px;margin-bottom:10px}
.workflow{display:flex;gap:26px;padding-top:18px;flex-wrap:wrap;border-top:1px solid var(--line);margin-top:18px;font-weight:700}
.workflow span{color:var(--muted);position:relative;padding-bottom:10px}.workflow span.active{color:var(--text)}
.workflow span.active::after{content:"";position:absolute;left:0;right:0;bottom:0;height:3px;border-radius:99px;background:var(--text)}
.list{display:grid;gap:12px}.task-card,.vendor-card{border:1px solid var(--line);border-radius:18px;padding:16px;background:#fff}
.task-top,.vendor-head,.subtitle{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap}
.task-title{font-size:17px;font-weight:800;margin-bottom:4px}.task-meta{color:var(--muted);font-size:13px}
.history{position:relative;padding-left:28px}.history::before{content:"";position:absolute;left:12px;top:10px;bottom:10px;width:3px;border-radius:99px;background:#dbe3ef}
.history-item{position:relative;padding:0 0 24px 24px}.history-item:last-child{padding-bottom:0}
.history-dot{position:absolute;left:-4px;top:6px;width:18px;height:18px;border-radius:999px;border:4px solid #fff;box-shadow:0 0 0 2px rgba(255,255,255,.85)}
.dot-blue{background:var(--primary-dark)}.dot-yellow{background:var(--warning)}.dot-red{background:#e56b63}.dot-green{background:#62c56d}.dot-violet{background:var(--violet)}.dot-orange{background:#ef8a15}
.history-title{font-size:16px;font-weight:800;display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:4px}.quote{font-style:italic;color:#637189;margin-top:8px}
.overdue{color:var(--danger);font-weight:800}.on-time{color:var(--success);font-weight:800}
@media (max-width: 1200px){.grid-2,.stats,.form-grid,.form-grid-3,.grid-3{grid-template-columns:1fr}}
@media (max-width: 920px){.app{grid-template-columns:1fr}.sidebar{display:none}.main{padding:18px}.topbar{flex-direction:column}}

